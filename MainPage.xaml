<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BeerRate_MAUI_App.ViewModels"
             x:Class="BeerRate_MAUI_App.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <!-- Header -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,20">
                <Label Text="Beer" 
                       FontSize="48" 
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Label Text="🍺" 
                       FontSize="64" 
                       VerticalOptions="Center"/>
                <Label Text="Rate" 
                       FontSize="48" 
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Add Beer Section -->
            <Frame BorderColor="LightGray" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Add New Beer" FontSize="20" FontAttributes="Bold"/>
                    
                    <Entry Placeholder="Beer Name" 
                           Text="{Binding BeerName}" 
                           ClearButtonVisibility="WhileEditing"/>
                    
                    <Entry Placeholder="Brewery" 
                           Text="{Binding Brewery}"
                           ClearButtonVisibility="WhileEditing"/>
                    
                    <Picker Title="Select Style" 
                            ItemsSource="{Binding BeerStyles}"
                            SelectedItem="{Binding Style}"/>
                    
                    <!-- Rating Buttons -->
                    <Label Text="Rating:" FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="5">
                        <Button Text="⭐ 1" 
                                Grid.Column="0"
                                Command="{Binding SetRatingCommand}"
                                CommandParameter="1"
                                BackgroundColor="{Binding Rating, Converter={StaticResource RatingColorConverter}, ConverterParameter=1}"/>
                        <Button Text="⭐ 2" 
                                Grid.Column="1"
                                Command="{Binding SetRatingCommand}"
                                CommandParameter="2"
                                BackgroundColor="{Binding Rating, Converter={StaticResource RatingColorConverter}, ConverterParameter=2}"/>
                        <Button Text="⭐ 3" 
                                Grid.Column="2"
                                Command="{Binding SetRatingCommand}"
                                CommandParameter="3"
                                BackgroundColor="{Binding Rating, Converter={StaticResource RatingColorConverter}, ConverterParameter=3}"/>
                        <Button Text="⭐ 4" 
                                Grid.Column="3"
                                Command="{Binding SetRatingCommand}"
                                CommandParameter="4"
                                BackgroundColor="{Binding Rating, Converter={StaticResource RatingColorConverter}, ConverterParameter=4}"/>
                        <Button Text="⭐ 5" 
                                Grid.Column="4"
                                Command="{Binding SetRatingCommand}"
                                CommandParameter="5"
                                BackgroundColor="{Binding Rating, Converter={StaticResource RatingColorConverter}, ConverterParameter=5}"/>
                    </Grid>
                    
                    <!-- Notes Field -->
                    <Editor Placeholder="Notes (optional)" 
                            Text="{Binding Notes}"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="80"
                            MaximumHeightRequest="150"/>
                    
                    <Button Text="Add Beer" 
                            Command="{Binding AddBeerCommand}"
                            BackgroundColor="#512BD4"
                            TextColor="White"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Search Section -->
            <Frame BorderColor="LightGray" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Search Beers" FontSize="20" FontAttributes="Bold"/>
                    <SearchBar Placeholder="Search by name, brewery, or style..."
                               Text="{Binding SearchText}"
                               SearchCommand="{Binding LoadBeersCommand}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Data Management Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="📥 Export CSV" 
                        Grid.Column="0"
                        Command="{Binding ExportToCsvCommand}"/>
                <Button Text="📊 View Stats" 
                        Grid.Column="1"
                        Command="{Binding ViewStatsCommand}"/>
            </Grid>

            <!-- Beer List -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <Label Text="Your Beer Ratings" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       Grid.Column="0"
                       VerticalOptions="Center"/>
                <Button Text="{Binding ShowAllButtonText}"
                        Grid.Column="1"
                        Command="{Binding ToggleShowAllCommand}"
                        BackgroundColor="LightGray"
                        TextColor="Black"
                        FontSize="12"
                        Padding="10,5"/>
            </Grid>
            
            <CollectionView ItemsSource="{Binding DisplayedBeerRatings}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray" 
                               CornerRadius="10" 
                               Padding="15" 
                               Margin="0,5"
                               HasShadow="True">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto">
                                <!-- Beer Details -->
                                <Label Text="{Binding BeerName}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="3"/>
                                
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Brewery: " FontAttributes="Bold"/>
                                            <Span Text="{Binding Brewery}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                
                                <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Style: " FontAttributes="Bold"/>
                                            <Span Text="{Binding Style}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                
                                <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Rating: " FontAttributes="Bold"/>
                                            <Span Text="{Binding Rating}"/>
                                            <Span Text=" ⭐"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <!-- Action Buttons -->
                                <Button Text="✏️ Edit" 
                                        Grid.Row="4"
                                        Grid.Column="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditBeerCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#512BD4"
                                        TextColor="White"
                                        FontSize="12"
                                        Padding="5"
                                        Margin="0,5,5,0"/>
                                
                                <Button Text="🗑️ Delete" 
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteBeerCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#DC3545"
                                        TextColor="White"
                                        FontSize="12"
                                        Padding="5"
                                        Margin="5,5,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No beers rated yet. Add your first beer above!" 
                           HorizontalOptions="Center"
                           Margin="0,20"
                           TextColor="Gray"/>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
